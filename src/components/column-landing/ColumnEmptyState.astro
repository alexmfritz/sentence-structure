---
import type { ColumnSlug } from '../../lib/columns';
import type { PlaceholderTile } from '../../lib/column-landing';

interface Props {
  column: ColumnSlug;
  placeholders: PlaceholderTile[];
}

const { column, placeholders } = Astro.props;
---

<section class="empty-tiles" data-column={column} aria-label="Coming to this column">
  <h2 class="empty-tiles__heading">Coming to this column</h2>
  <div class="empty-tiles__grid">
    {
      placeholders.slice(0, 3).map((tile) => (
        <article class="empty-tile">
          <div class="empty-tile__bg" aria-hidden="true" />
          <div class="empty-tile__content">
            <span class="empty-tile__eyebrow">{tile.eyebrow}</span>
            <h3 class="empty-tile__title">{tile.title}</h3>
            <span class="empty-tile__status">Forthcoming</span>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .empty-tiles {
    max-width: 1100px;
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  .empty-tiles__heading {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0 0 1.25rem;
    text-align: center;
  }

  .empty-tiles__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .empty-tile {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: 4px;
    overflow: hidden;
  }

  .empty-tile__bg {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--column-500) 18%, var(--color-bg-elevated));
    border: 1px dashed var(--column-600);
    border-radius: 4px;
    opacity: 0.45;
  }

  .empty-tile__content {
    position: absolute;
    inset: 0;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .empty-tile__eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--column-200);
  }

  .empty-tile__title {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.4;
    font-weight: 400;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .empty-tile__status {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .empty-tiles__grid {
      grid-template-columns: 1fr;
    }
    .empty-tile {
      aspect-ratio: 5 / 3;
    }
  }
</style>
