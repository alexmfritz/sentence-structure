---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import ColumnTagPill from '../post/ColumnTagPill.astro';
import MenuWheel from '../chrome/MenuWheel.astro';
import HamburgerMenu from '../chrome/HamburgerMenu.astro';
import landingHero from '../../assets/landing-hero.png';

interface Props {
  post?: CollectionEntry<'memoir'>;
}

const { post } = Astro.props;
const href = post ? `/memoir/${post.id}` : '/memoir/';
const title = post ? post.data.title : 'Memoir, forthcoming.';
const deck = post
  ? post.data.deck
  : 'The chronological spine of this publication, written in pieces as the pieces find their shape.';
const cta = post ? 'Read piece →' : 'See the spine →';
---

<section class="hero" data-column="memoir" aria-labelledby="hero-title">
  <Image
    src={landingHero}
    alt=""
    class="hero__image"
    widths={[768, 1280, 1920, 2752]}
    sizes="100vw"
    format="webp"
    loading="eager"
    aria-hidden="true"
  />

  <MenuWheel />
  <HamburgerMenu />

  <div class="hero__glass">
    <ColumnTagPill column="memoir" />
    <h2 class="hero__title" id="hero-title">{title}</h2>
    {deck && <p class="hero__deck">{deck}</p>}
    <a class="hero__cta" href={href}>{cta}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg);
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__glass {
    position: absolute;
    bottom: 2.5rem;
    left: 2rem;
    right: 2rem;
    max-width: 520px;
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: var(--glass-floating);
    backdrop-filter: var(--glass-blur-strong);
    border: 1px solid var(--glass-border);
    border-radius: 4px;
    color: var(--color-text);
    transition: background 0.2s ease;
  }

  .hero__glass:has(.hero__cta:hover) {
    background: var(--glass-floating-hover);
  }

  .hero__title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 2.3vw + 29px, 52px);
    line-height: 1.1;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .hero__deck {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.45;
    font-style: italic;
    color: var(--color-text);
    margin: 0;
    max-width: 42ch;
  }

  .hero__cta {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--column-200);
    margin-top: 0.25rem;
    text-decoration: none;
    align-self: flex-start;
    padding: 0.25rem 0;
    transition: color 0.15s ease;
  }

  .hero__cta:hover {
    color: var(--column-100);
  }

  .hero__cta:focus-visible {
    outline: 2px solid var(--color-structural-300);
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .hero__glass {
      bottom: 1.25rem;
      left: 1rem;
      right: 1rem;
      padding: 1.25rem;
      gap: 0.6rem;
    }
    .hero {
      aspect-ratio: 4 / 5;
    }
  }

  /* prefers-reduced-transparency handled globally in global.css. */
</style>
