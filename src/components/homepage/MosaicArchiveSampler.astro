---
import type { HomepagePost } from '../../lib/homepage';
import { COLUMNS } from '../../lib/columns';

interface Props {
  posts: HomepagePost[];
}

const { posts } = Astro.props;
const trio = posts.slice(0, 3);
---

<section class="sampler" aria-label="Archive sampler">
  {
    trio.map((post) => (
      <a
        class="sampler__tile"
        href={`/${post.collection}/${post.id}`}
        data-column={post.collection}
      >
        <div class="sampler__bg" aria-hidden="true" />
        <div class="sampler__content">
          <span class="tile__pill">{COLUMNS[post.collection].name}</span>
          <h3 class="sampler__title">{post.data.title || '[ untitled ]'}</h3>
        </div>
      </a>
    ))
  }

  <a class="sampler__tile sampler__tile--archive" href="/archive">
    <div class="sampler__bg" aria-hidden="true" />
    <div class="sampler__content sampler__content--center">
      <span class="sampler__archive-eyebrow">Archive</span>
      <span class="sampler__archive-cta">View all →</span>
    </div>
  </a>
</section>

<style>
  .sampler {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin: 2.5rem auto;
    max-width: 1100px;
    padding: 0 1.5rem;
  }

  .sampler__tile {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  .sampler__tile:hover {
    transform: translateY(-2px);
  }

  .sampler__bg {
    position: absolute;
    inset: 0;
    background: color-mix(in oklch, var(--column-500) 25%, var(--color-bg-elevated));
    border: 1px solid var(--column-600);
    border-radius: 4px;
    transition: background 0.2s ease;
  }

  .sampler__tile:hover .sampler__bg {
    background: color-mix(in oklch, var(--column-500) 40%, var(--color-bg-elevated));
  }

  .sampler__tile--archive .sampler__bg {
    background: var(--color-bg-elevated);
    border: 1px dashed var(--color-border);
  }

  .sampler__tile--archive:hover .sampler__bg {
    background: color-mix(in oklch, var(--color-bg-elevated) 80%, var(--color-structural-500));
    border-color: var(--color-structural-400);
  }

  .sampler__content {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sampler__content--center {
    inset: 0;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.4rem;
  }

  .sampler__title {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.25;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .sampler__archive-eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .sampler__archive-cta {
    font-family: var(--font-serif);
    font-size: 18px;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .sampler {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
