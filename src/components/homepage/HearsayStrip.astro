---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { extractFirstLine } from '../../lib/content';
import hearsayCover from '../../assets/hearsay-landing-hero.png';

interface Props {
  posts: CollectionEntry<'hearsay'>[];
}

const { posts } = Astro.props;

const cards = posts.map((post) => ({
  id: post.id,
  label: post.data.title.trim() || extractFirstLine(post.body ?? ''),
  untitled: !post.data.title.trim(),
  heroImage: post.data.heroImage,
}));
---

<section class="hearsay-strip" data-column="hearsay" aria-labelledby="hearsay-strip-heading">
  <div class="hearsay-strip__head">
    <h2 id="hearsay-strip-heading" class="hearsay-strip__heading">Hearsay</h2>
    <p class="hearsay-strip__tagline">Yes, this really happened.</p>
  </div>

  <ul class="hearsay-strip__track">
    {
      cards.map((card) => (
        <li class="hearsay-strip__item">
          <a class="hearsay-strip__card" href={`/hearsay/${card.id}`}>
            {card.heroImage && (
              <Fragment>
                <Image
                  src={card.heroImage}
                  alt=""
                  class="hearsay-strip__card-bg"
                  widths={[240, 440]}
                  sizes="220px"
                  format="webp"
                />
                <span class="hearsay-strip__card-scrim" aria-hidden="true" />
              </Fragment>
            )}
            <span class="hearsay-strip__card-content">
              <span class:list={['hearsay-strip__card-title', card.untitled && 'is-untitled']}>
                {card.label}
              </span>
            </span>
          </a>
        </li>
      ))
    }
    <li class="hearsay-strip__item hearsay-strip__item--all">
      <a class="hearsay-strip__view-all" href="/hearsay">
        <Image
          src={hearsayCover}
          alt=""
          class="hearsay-strip__view-all-bg"
          widths={[240, 440]}
          sizes="220px"
          format="webp"
        />
        <span class="hearsay-strip__view-all-scrim" aria-hidden="true"></span>
        <span class="hearsay-strip__view-all-content">
          <span class="hearsay-strip__view-all-label">Hearsay</span>
          <span class="hearsay-strip__view-all-cta">View all &rarr;</span>
        </span>
      </a>
    </li>
  </ul>
</section>

<style>
  .hearsay-strip {
    max-width: 1100px;
    margin: 3.5rem auto;
    padding: 0 1.5rem;
  }

  .hearsay-strip__head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }

  .hearsay-strip__heading {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--column-200);
    margin: 0;
  }

  .hearsay-strip__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* Manual horizontal scroll — overflow-x:auto self-activates only when the
     cards actually exceed the viewport width, so a handful of cards just sit
     left-aligned (no empty scroll track). Deliberately NOT an auto-ticker. */
  .hearsay-strip__track {
    list-style: none;
    margin: 0;
    padding: 0 0 0.75rem;
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: thin;
  }

  .hearsay-strip__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
  }

  .hearsay-strip__card {
    position: relative;
    display: flex;
    align-items: flex-end;
    width: 220px;
    height: 120px;
    padding: 1rem;
    border: 1px solid var(--column-600);
    border-radius: 4px;
    background: color-mix(in oklch, var(--column-500) 18%, var(--color-bg-elevated));
    text-decoration: none;
    overflow: hidden;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .hearsay-strip__card:hover {
    background: color-mix(in oklch, var(--column-500) 32%, var(--color-bg-elevated));
    border-color: var(--column-400);
  }

  /* Per-post cards: when the post supplies a heroImage, render it as a
     full-bleed background behind a scrim with the title sitting above.
     Same pattern as the terminal View All → card. */
  .hearsay-strip__card-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hearsay-strip__card-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      oklch(0.12 0.02 340 / 0.45) 0%,
      oklch(0.12 0.02 340 / 0.6) 55%,
      oklch(0.1 0.02 340 / 0.88) 100%
    );
    transition: opacity 0.2s ease;
  }

  .hearsay-strip__card:hover .hearsay-strip__card-scrim {
    opacity: 0.82;
  }

  .hearsay-strip__card-content {
    position: relative;
  }

  .hearsay-strip__card-title {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-text);
    /* Teaser surface: one line only. Full bodies live on the landing. */
    display: -webkit-box;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hearsay-strip__card-title.is-untitled {
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .hearsay-strip__item--all {
    display: flex;
  }

  /* Column-cover terminal card: the column's representative art behind a
     strong scrim (the image is bright/busy) with a bottom-anchored label. */
  .hearsay-strip__view-all {
    position: relative;
    display: block;
    width: 220px;
    height: 120px;
    border: 1px solid var(--column-600);
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
  }

  .hearsay-strip__view-all-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hearsay-strip__view-all-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      oklch(0.12 0.02 340 / 0.45) 0%,
      oklch(0.12 0.02 340 / 0.6) 55%,
      oklch(0.1 0.02 340 / 0.88) 100%
    );
    transition: opacity 0.2s ease;
  }

  .hearsay-strip__view-all:hover .hearsay-strip__view-all-scrim {
    opacity: 0.82;
  }

  .hearsay-strip__view-all-content {
    position: absolute;
    inset: auto 0 0 0;
    padding: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .hearsay-strip__view-all-label {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--color-text);
  }

  .hearsay-strip__view-all-cta {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    color: var(--column-100);
  }

  .hearsay-strip__card:focus-visible,
  .hearsay-strip__view-all:focus-visible {
    outline: 2px solid var(--column-300);
    outline-offset: 2px;
  }
</style>
