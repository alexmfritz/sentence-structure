---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { HomepagePost } from '../../lib/homepage';
import { COLUMNS, type ColumnSlug } from '../../lib/columns';
import memoirColumn from '../../assets/memoir-column.png';
import concreteTruthsColumn from '../../assets/concrete-truths-column.png';
import economicsOfColumn from '../../assets/economics-of-column.png';

interface Props {
  showcase: Array<{ column: ColumnSlug; post: HomepagePost | undefined }>;
}

const { showcase } = Astro.props;

// Column-identity images for the showcase tiles (2:3 portrait).
const COLUMN_IMAGES: Partial<Record<ColumnSlug, ImageMetadata>> = {
  memoir: memoirColumn,
  'concrete-truths': concreteTruthsColumn,
  'economics-of': economicsOfColumn,
};
---

{/* TODO Phase 4+: revisit Row 2 with all five columns; spec flagged.
    Currently 3 prison-experience columns per the foundational doc. */}
<section class="showcase" aria-label="Columns">
  {
    showcase.map(({ column, post }) => {
      const meta = COLUMNS[column];
      const columnImage = COLUMN_IMAGES[column];
      return (
        <a
          class="showcase__tile"
          href={`/${column}`}
          data-column={column}
          aria-label={`${meta.name} — ${post ? `latest: ${post.data.title}` : 'no posts yet'}`}
        >
          {columnImage ? (
            <Fragment>
              <Image
                src={columnImage}
                alt=""
                class="showcase__image"
                widths={[340, 560, 680]}
                sizes="(min-width: 769px) 340px, 100vw"
                format="webp"
              />
              <div class="showcase__scrim" aria-hidden="true" />
            </Fragment>
          ) : (
            <div class="showcase__bg" aria-hidden="true" />
          )}
          <div class="showcase__content">
            <span class="showcase__eyebrow">Column</span>
            <h3 class="showcase__name">{meta.name}</h3>
            <p class="showcase__deck">{meta.deck}</p>
            <div class="showcase__divider" aria-hidden="true" />
            {post ? (
              <div class="showcase__latest">
                <span class="showcase__latest-label">Most recent</span>
                <span class="showcase__latest-title">{post.data.title}</span>
              </div>
            ) : (
              <div class="showcase__latest showcase__latest--empty">
                <span class="showcase__latest-label">Forthcoming</span>
                <span class="showcase__latest-title">[ First piece coming soon ]</span>
              </div>
            )}
          </div>
        </a>
      );
    })
  }
</section>

<style>
  .showcase {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 2.5rem auto;
    max-width: 1100px;
    padding: 0 1.5rem;
  }

  .showcase__tile {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    color: var(--color-text);
    text-decoration: none;
    border: 1px solid var(--column-600);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  .showcase__tile:hover {
    transform: translateY(-2px);
  }

  /* Fallback background when a showcase column has no identity image. */
  .showcase__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      170deg,
      color-mix(in oklch, var(--column-400) 35%, var(--color-bg-elevated)) 0%,
      color-mix(in oklch, var(--column-500) 28%, var(--color-bg)) 100%
    );
    border-radius: 4px;
  }

  /* Column identity image + legibility scrim. The scrim darkens top
     and bottom so the eyebrow/name and the latest-post line stay
     readable over the artwork. */
  .showcase__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .showcase__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      oklch(0.1 0.01 280 / 0.8) 0%,
      oklch(0.12 0.01 280 / 0.32) 42%,
      oklch(0.08 0.01 280 / 0.85) 100%
    );
    transition: opacity 0.2s ease;
  }

  .showcase__tile:hover .showcase__scrim {
    opacity: 0.86;
  }

  .showcase__content {
    position: relative;
    height: 100%;
    padding: 1.75rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .showcase__eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--column-200);
  }

  .showcase__name {
    font-family: var(--font-serif);
    font-size: 30px;
    line-height: 1.15;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .showcase__deck {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.45;
    font-style: italic;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .showcase__divider {
    margin-top: auto;
    height: 1px;
    background: color-mix(in oklch, var(--column-600) 70%, transparent);
  }

  .showcase__latest {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .showcase__latest-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .showcase__latest-title {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.3;
    color: var(--color-text);
  }

  .showcase__latest--empty .showcase__latest-title {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .showcase {
      grid-template-columns: 1fr;
    }
    .showcase__tile {
      aspect-ratio: 5 / 3;
    }
  }
</style>
