---
import { COLUMNS_LIST } from '../../lib/columns';
---

<aside class="where-to-start" aria-labelledby="where-to-start-heading">
  <h2 id="where-to-start-heading" class="where-to-start__heading">Where to start</h2>
  <dl class="where-to-start__list">
    {
      COLUMNS_LIST.map((column) => (
        <div class="where-to-start__entry">
          <dt class="where-to-start__name">
            <a href={`/${column.slug}`}>{column.name}</a>
          </dt>
          <dd class="where-to-start__deck">{column.deck}</dd>
        </div>
      ))
    }
  </dl>
</aside>

<style>
  .where-to-start {
    margin: 3rem 0;
    padding: 2rem 0 1.75rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .where-to-start__heading {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0 0 1.5rem;
  }

  .where-to-start__list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .where-to-start__entry {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.25rem;
    align-items: baseline;
  }

  .where-to-start__name {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
  }

  .where-to-start__name a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-structural-500);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .where-to-start__name a:hover {
    text-decoration-color: var(--color-structural-300);
  }

  .where-to-start__deck {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 640px) {
    .where-to-start__entry {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
