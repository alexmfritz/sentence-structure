---
import { COLUMNS_ALPHABETICAL } from '../../lib/columns';

// Mark the current column's pill via aria-current on its exact landing page.
// Post pages (/memoir/slug) are not the column landing, so no pill is "page"
// there — semantically correct, and the resting tint still reads as a legend.
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isColumnCurrent = (slug: string) => current === `/${slug}`;
---

<header class="top-nav">
  <div class="top-nav__inner">
    <a href="/" class="top-nav__wordmark">Sentence Structure</a>

    <nav class="top-nav__links" aria-label="Primary">
      <details class="top-nav__columns">
        <summary>Columns</summary>
        <ul class="top-nav__columns-list">
          {
            COLUMNS_ALPHABETICAL.map((column) => (
              <li>
                <a
                  href={`/${column.slug}`}
                  data-column={column.slug}
                  aria-current={isColumnCurrent(column.slug) ? 'page' : undefined}
                >
                  {column.name}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <a href="/about">About</a>
      <a href="/archive">Archive</a>
      <a href="#newsletter">Newsletter</a>
    </nav>
  </div>
</header>

<style>
  .top-nav {
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .top-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  /* Wordmark = publication, not a column → structural voice color (ties it
     to the manifesto strip + newsletter). Color only; geometry unchanged. */
  .top-nav__wordmark {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-structural-100);
    background: var(--color-structural-600);
    text-decoration: none;
    transition: background-color 120ms ease, color 120ms ease;
  }

  .top-nav__wordmark:hover {
    background: var(--color-structural-500);
  }

  .top-nav__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-sans);
    font-size: 14px;
  }

  .top-nav__links > a,
  .top-nav__columns > summary {
    color: var(--color-text-secondary);
    text-decoration: none;
    cursor: pointer;
    list-style: none;
  }

  .top-nav__links > a:hover,
  .top-nav__columns > summary:hover {
    color: var(--color-text);
  }

  .top-nav__columns {
    position: relative;
  }

  .top-nav__columns > summary::-webkit-details-marker {
    display: none;
  }

  .top-nav__columns[open] > summary {
    color: var(--color-text);
  }

  .top-nav__columns-list {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    min-width: 200px;
    margin: 0;
    padding: 0.75rem 0;
    list-style: none;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    box-shadow: 0 8px 24px var(--shadow-color);
    z-index: 50;
  }

  /* Column pills consume the generic --column-* vars supplied by the global
     [data-column] block — same mechanism the Hearsay components use. No
     hardcoded color here; geometry (padding, left rule) is unchanged. */
  .top-nav__columns-list a {
    display: block;
    padding: 0.5rem 1rem;
    text-decoration: none;
    border-left: 2px solid transparent;
    background: var(--column-600);
    color: var(--column-200);
    transition: background-color 120ms ease, color 120ms ease;
  }

  .top-nav__columns-list a:hover,
  .top-nav__columns-list a[aria-current='page'] {
    background: var(--column-500);
    color: var(--column-100);
    border-left-color: var(--column-300);
  }

  .top-nav__columns-list a:focus-visible {
    outline: 2px solid var(--column-300);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .top-nav__links {
      gap: 1rem;
      font-size: 13px;
    }
  }
</style>
