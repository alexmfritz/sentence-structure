---
import { COLUMNS_LIST } from '../../lib/columns';
---

<header class="top-nav">
  <div class="top-nav__inner">
    <a href="/" class="top-nav__wordmark">Sentence Structure</a>

    <nav class="top-nav__links" aria-label="Primary">
      <details class="top-nav__columns">
        <summary>Columns</summary>
        <ul class="top-nav__columns-list">
          {
            COLUMNS_LIST.map((column) => (
              <li>
                <a href={`/${column.slug}`} style={`--column-300: var(--color-${column.slug}-300)`}>
                  {column.name}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
      <a href="/archive">Archive</a>
      <a href="/about">About</a>
      <a href="#newsletter">Newsletter</a>
    </nav>
  </div>
</header>

<style>
  .top-nav {
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .top-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  .top-nav__wordmark {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-decoration: none;
  }

  .top-nav__links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-sans);
    font-size: 14px;
  }

  .top-nav__links > a,
  .top-nav__columns > summary {
    color: var(--color-text-secondary);
    text-decoration: none;
    cursor: pointer;
    list-style: none;
  }

  .top-nav__links > a:hover,
  .top-nav__columns > summary:hover {
    color: var(--color-text);
  }

  .top-nav__columns {
    position: relative;
  }

  .top-nav__columns > summary::-webkit-details-marker {
    display: none;
  }

  .top-nav__columns[open] > summary {
    color: var(--color-text);
  }

  .top-nav__columns-list {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    min-width: 200px;
    margin: 0;
    padding: 0.75rem 0;
    list-style: none;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    box-shadow: 0 8px 24px var(--shadow-color);
    z-index: 50;
  }

  .top-nav__columns-list a {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
  }

  .top-nav__columns-list a:hover {
    color: var(--color-text);
    border-left-color: var(--column-300);
  }

  @media (max-width: 640px) {
    .top-nav__links {
      gap: 1rem;
      font-size: 13px;
    }
  }
</style>
