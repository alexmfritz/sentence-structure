---
interface Props {
  variant?: 'column' | 'structural';
}

const { variant = 'column' } = Astro.props;
---

<div class="reading-progress" aria-hidden="true">
  <div class:list={['reading-progress__fill', `reading-progress__fill--${variant}`]}></div>
</div>

<script>
  const fill = document.querySelector<HTMLElement>('.reading-progress__fill');
  if (fill) {
    const update = () => {
      const scrollTop = window.scrollY;
      const scrollable =
        document.documentElement.scrollHeight - window.innerHeight;
      const ratio = scrollable > 0 ? scrollTop / scrollable : 0;
      fill.style.width = `${Math.min(100, Math.max(0, ratio * 100))}%`;
    };
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 100;
    pointer-events: none;
    background: transparent;
  }

  .reading-progress__fill {
    height: 100%;
    width: 0;
    transition: width 0.05s linear;
  }

  .reading-progress__fill--column {
    background: var(--column-400);
  }

  .reading-progress__fill--structural {
    background: var(--color-structural-400);
  }
</style>
