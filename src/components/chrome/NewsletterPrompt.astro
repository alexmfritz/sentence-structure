---
interface Props {
  heading?: string;
  deck?: string;
}

const {
  heading = 'A short note when new pieces publish.',
  deck = 'No promotion, no list resale, no other publications.',
} = Astro.props;
---

<aside class="newsletter-prompt" id="newsletter">
  <p class="newsletter-prompt__eyebrow">Newsletter</p>
  <h2 class="newsletter-prompt__heading">{heading}</h2>
  <p class="newsletter-prompt__deck">{deck}</p>

  <form class="newsletter-prompt__form" onsubmit="return false;" aria-label="Newsletter signup">
    <label class="newsletter-prompt__label" for="newsletter-email">Email address</label>
    <div class="newsletter-prompt__row">
      <input
        id="newsletter-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />
      <button type="submit">Subscribe</button>
    </div>
  </form>
</aside>

<style>
  .newsletter-prompt {
    max-width: 480px;
    margin: 4rem auto;
    padding: 2rem 1.75rem;
    border: 1px solid var(--color-structural-600);
    background: color-mix(in oklch, var(--color-structural-500) 18%, var(--color-bg-elevated));
    border-radius: 4px;
  }

  .newsletter-prompt__eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-structural-200);
    margin: 0 0 0.5rem;
  }

  .newsletter-prompt__heading {
    font-family: var(--font-serif);
    font-size: 24px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .newsletter-prompt__deck {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.45;
    font-style: italic;
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem;
    max-width: 38ch;
  }

  .newsletter-prompt__label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .newsletter-prompt__row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .newsletter-prompt__row input {
    flex: 1;
    min-width: 200px;
    padding: 0.625rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 3px;
  }

  .newsletter-prompt__row input:focus {
    outline: none;
    border-color: var(--color-structural-300);
  }

  .newsletter-prompt__row button {
    padding: 0.625rem 1.25rem;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-structural-400);
    border: 1px solid var(--color-structural-300);
    border-radius: 3px;
    cursor: pointer;
  }

  .newsletter-prompt__row button:hover {
    background: var(--color-structural-300);
  }
</style>
