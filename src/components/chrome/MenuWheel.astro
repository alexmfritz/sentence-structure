---
import { COLUMNS_ALPHABETICAL } from '../../lib/columns';

// Two axes, two categories. Columns are content → the colored down-left
// cascade (the color legend). Pages (Archive, About) are utility nav → a
// separate neutral horizontal pair, level with the trigger, the way the
// wordmark pill sits. This mirrors the split the mobile HamburgerMenu already
// makes (its "Columns" vs "Read" groups); the wheel was the odd one out.
const columnItems = COLUMNS_ALPHABETICAL.map((c) => ({
  label: c.name,
  href: `/${c.slug}`,
  column: c.slug,
}));

const utilityItems = [
  { label: 'About', href: '/about' },
  { label: 'Archive', href: '/archive' },
];

const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isCurrent = (href: string) => current === href.replace(/\/+$/, '');
---

<nav class="menu-wheel" aria-label="Site navigation" data-menu-wheel>
  <button
    class="menu-wheel__trigger"
    type="button"
    aria-expanded="false"
    aria-controls="menu-wheel-items menu-wheel-utils"
    aria-haspopup="menu"
    aria-label="Open menu"
  >
    <span class="menu-wheel__trigger-bar"></span>
    <span class="menu-wheel__trigger-bar"></span>
    <span class="menu-wheel__trigger-bar"></span>
  </button>

  <ul
    id="menu-wheel-items"
    class="menu-wheel__items"
    role="menu"
    aria-label="Columns"
    data-open="false"
  >
    {
      columnItems.map((item, i) => (
        <li
          class="menu-wheel__item"
          style={`--i: ${i}; --total: ${columnItems.length};`}
          data-column={item.column}
        >
          <a
            href={item.href}
            role="menuitem"
            tabindex="-1"
            aria-current={isCurrent(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <ul
    id="menu-wheel-utils"
    class="menu-wheel__utils"
    role="menu"
    aria-label="Pages"
    data-open="false"
  >
    {
      utilityItems.map((item, j) => (
        <li class="menu-wheel__util" style={`--j: ${j};`}>
          <a
            href={item.href}
            role="menuitem"
            tabindex="-1"
            aria-current={isCurrent(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  type WheelEl = HTMLElement;

  const wheels = document.querySelectorAll<WheelEl>('[data-menu-wheel]');
  wheels.forEach((wheel) => {
    const trigger = wheel.querySelector<HTMLButtonElement>('.menu-wheel__trigger');
    // Both axes toggle together; keyboard traverses all items in DOM order
    // (columns first, then pages) so open-focus lands on the first column.
    const lists = wheel.querySelectorAll<HTMLElement>('[data-open]');
    const links = wheel.querySelectorAll<HTMLAnchorElement>('a[role="menuitem"]');
    if (!trigger || !lists.length) return;

    const setOpen = (open: boolean) => {
      trigger.setAttribute('aria-expanded', String(open));
      lists.forEach((l) => {
        l.dataset.open = String(open);
      });
      links.forEach((a) => {
        a.tabIndex = open ? 0 : -1;
      });
      trigger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    const isOpen = () =>
      Array.from(lists).some((l) => l.dataset.open === 'true');

    trigger.addEventListener('click', () => {
      const willOpen = !isOpen();
      setOpen(willOpen);
      if (willOpen) {
        // focus first item shortly after open so the focus ring is visible
        requestAnimationFrame(() => links[0]?.focus());
      }
    });

    wheel.addEventListener('keydown', (e) => {
      const event = e as KeyboardEvent;
      if (event.key === 'Escape' && isOpen()) {
        setOpen(false);
        trigger.focus();
        return;
      }
      if (!isOpen()) return;

      const focusables = Array.from(links);
      const idx = focusables.indexOf(document.activeElement as HTMLAnchorElement);
      if (event.key === 'ArrowDown' || event.key === 'ArrowRight') {
        event.preventDefault();
        const next = focusables[(idx + 1) % focusables.length];
        next?.focus();
      } else if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') {
        event.preventDefault();
        const prev =
          focusables[(idx - 1 + focusables.length) % focusables.length];
        prev?.focus();
      } else if (event.key === 'Home') {
        event.preventDefault();
        focusables[0]?.focus();
      } else if (event.key === 'End') {
        event.preventDefault();
        focusables[focusables.length - 1]?.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (isOpen() && !wheel.contains(e.target as Node)) setOpen(false);
    });
  });
</script>

<style>
  .menu-wheel {
    position: absolute;
    /* Center the 48px trigger (and the Pages pills, which share its band) on
       the same line as the home-header wordmark pill, whose center sits ~34px
       from the top → trigger top = 34 - 24. */
    top: 10px;
    right: 1.25rem;
    z-index: 20;
  }

  .menu-wheel__trigger {
    width: 48px;
    height: 48px;
    padding: 0;
    border-radius: 999px;
    background: var(--glass-trigger);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border-strong);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    transition: background 0.15s ease;
  }

  .menu-wheel__trigger:hover,
  .menu-wheel__trigger[aria-expanded='true'] {
    background: var(--glass-trigger-hover);
  }

  .menu-wheel__trigger:focus-visible {
    outline: 2px solid var(--color-structural-300);
    outline-offset: 2px;
  }

  .menu-wheel__trigger-bar {
    width: 18px;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .menu-wheel__trigger[aria-expanded='true'] .menu-wheel__trigger-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-wheel__trigger[aria-expanded='true'] .menu-wheel__trigger-bar:nth-child(2) {
    opacity: 0;
  }
  .menu-wheel__trigger[aria-expanded='true'] .menu-wheel__trigger-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .menu-wheel__items {
    position: absolute;
    top: 60px;
    right: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    pointer-events: none;
  }

  .menu-wheel__items[data-open='true'] {
    pointer-events: auto;
  }

  /* Staircase cascade. Each item descends by a fixed (--step-x, --step-y)
     from the one above it. DOM order matches visual order: item 0 (Memoir)
     sits closest to the trigger; item N sits furthest down-and-left.
     Reads as a wedge because items get progressively further from the
     trigger axis along both dimensions, but uniform spacing prevents the
     pill-overlap that an arc layout produces with variable-width labels. */
  .menu-wheel__item {
    --step-x: -32px;
    --step-y: 56px;
    --start-y: 16px;
    position: absolute;
    top: 0;
    right: 0;
    transform: translate(0, 0) scale(0.6);
    opacity: 0;
    transition:
      transform 0.32s cubic-bezier(0.18, 0.74, 0.28, 1),
      opacity 0.22s ease;
  }

  .menu-wheel__items[data-open='true'] .menu-wheel__item {
    transform:
      translate(
        calc(var(--i) * var(--step-x)),
        calc(var(--start-y) + var(--i) * var(--step-y))
      )
      scale(1);
    opacity: 1;
    transition-delay: calc(var(--i) * 30ms);
  }

  .menu-wheel__item a {
    display: inline-block;
    min-width: 168px;
    padding: 0.5rem 1rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    background: var(--glass-pill);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    white-space: nowrap;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .menu-wheel__item[data-column='memoir'] a:hover         { border-color: var(--color-memoir-400); }
  .menu-wheel__item[data-column='concrete-truths'] a:hover { border-color: var(--color-concrete-truths-400); }
  .menu-wheel__item[data-column='economics-of'] a:hover    { border-color: var(--color-economics-of-400); }
  .menu-wheel__item[data-column='off-the-record'] a:hover  { border-color: var(--color-off-the-record-400); }
  .menu-wheel__item[data-column='protective-factors'] a:hover { border-color: var(--color-protective-factors-400); }
  .menu-wheel__item[data-column='hearsay'] a:hover         { border-color: var(--color-hearsay-400); }

  .menu-wheel__item a:hover {
    background: var(--glass-pill-hover);
  }

  .menu-wheel__item a:focus-visible {
    outline: 2px solid var(--color-structural-300);
    outline-offset: 2px;
  }

  /* Column items get solid column fills (the nav becomes a color legend);
     the Pages axis stays neutral glass. Vars come from the global
     [data-column] block. Solid fill → prefers-reduced-transparency
     unaffected. */
  .menu-wheel__item[data-column] a {
    background: var(--column-600);
    color: var(--column-200);
  }

  .menu-wheel__item[data-column] a:hover,
  .menu-wheel__item[data-column] a[aria-current='page'] {
    background: var(--column-500);
    color: var(--column-100);
  }

  .menu-wheel__item[data-column] a:focus-visible {
    outline: 2px solid var(--column-300);
    outline-offset: 2px;
  }

  /* Pages axis. A neutral horizontal pair that extends left from the trigger
     at the trigger's own height — the same band the wordmark pill sits in.
     Deliberately NOT colored: these are utility nav, not columns, and keeping
     them off the cascade is the whole point. Flex handles the variable pill
     widths; the slide-in is decoupled from layout so labels can be any size. */
  .menu-wheel__utils {
    position: absolute;
    top: 0;
    right: 60px; /* trigger (48px) at right:0 + 12px gap */
    height: 48px; /* match trigger → vertically centered on it */
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    pointer-events: none;
  }

  .menu-wheel__utils[data-open='true'] {
    pointer-events: auto;
  }

  .menu-wheel__util {
    transform: translateX(14px) scale(0.92);
    opacity: 0;
    transition:
      transform 0.3s cubic-bezier(0.18, 0.74, 0.28, 1),
      opacity 0.22s ease;
  }

  .menu-wheel__utils[data-open='true'] .menu-wheel__util {
    transform: translateX(0) scale(1);
    opacity: 1;
    transition-delay: calc(var(--j) * 40ms);
  }

  .menu-wheel__util a {
    display: inline-block;
    /* Equal-width Pages pills, a step up from natural label width but kept
       below the 168px column pills so the column axis stays primary. */
    min-width: 144px;
    padding: 0.5rem 1rem;
    text-align: center;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    background: var(--glass-pill);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    white-space: nowrap;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .menu-wheel__util a:hover,
  .menu-wheel__util a[aria-current='page'] {
    background: var(--glass-pill-hover);
  }

  .menu-wheel__util a:focus-visible {
    outline: 2px solid var(--color-structural-300);
    outline-offset: 2px;
  }

  /* prefers-reduced-motion: keep both layouts but skip the animation. */
  @media (prefers-reduced-motion: reduce) {
    .menu-wheel__item,
    .menu-wheel__items[data-open='true'] .menu-wheel__item,
    .menu-wheel__util,
    .menu-wheel__utils[data-open='true'] .menu-wheel__util {
      transition: none;
      transition-delay: 0s;
    }
  }

  /* prefers-reduced-transparency handled globally in global.css by
     overriding the --glass-* tokens. No per-component block needed. */

  /* Hidden on small viewports — the HamburgerMenu takes over there. */
  @media (max-width: 768px) {
    .menu-wheel {
      display: none;
    }
  }
</style>
