---
// Quiet, piece-specific reader note at the top of an article body.
// Author writes the prose inside the slot; the component supplies the
// "Content note" label and the neutral frame, so every note is labeled
// consistently and recognizably.
//
// Not column-themed — reads as publication-care voice, not column voice.
---

<aside class="content-note" aria-label="Content note">
  <p class="content-note__label">Content note</p>
  <div class="content-note__body">
    <slot />
  </div>
</aside>

<style>
  .content-note {
    margin-block: 1.75rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .content-note__label {
    font-family: var(--font-sans);
    font-size: 12px;
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-tertiary);
    margin: 0 0 0.5rem;
  }

  .content-note__body {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .content-note__body :global(p) {
    margin: 0;
  }

  .content-note__body :global(p + p) {
    margin-top: 1rem;
  }
</style>
