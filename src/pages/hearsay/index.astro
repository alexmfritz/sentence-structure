---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNav from '../../components/chrome/TopNav.astro';
import NewsletterPrompt from '../../components/chrome/NewsletterPrompt.astro';
import ColumnHeader from '../../components/column-landing/ColumnHeader.astro';
import ColumnSubscribePrompt from '../../components/column-landing/ColumnSubscribePrompt.astro';
import HearsayFeed from '../../components/column-landing/HearsayFeed.astro';
import { getCollection } from 'astro:content';
import { COLUMNS } from '../../lib/columns';
import { COLUMN_EMPTY_STATES } from '../../lib/column-landing';
import { HEARSAY_SPARSE_THRESHOLD } from '../../lib/hearsay';
import hearsayLandingHero from '../../assets/hearsay-landing-hero.png';

const meta = COLUMNS['hearsay'];
const empty = COLUMN_EMPTY_STATES['hearsay'];
const posts = await getCollection('hearsay');
const isEmpty = posts.length === 0;
// Manifesto persists through the sparse launch state, not only at zero posts.
const isSparse = posts.length < HEARSAY_SPARSE_THRESHOLD;
---

<BaseLayout title={`${meta.name} — Sentence Structure`} description={meta.deck}>
  <div data-column="hearsay">
    <TopNav />

    <ColumnHeader
      column="hearsay"
      manifesto={isSparse ? empty.manifesto : undefined}
    />

    <figure class="hearsay-landing-hero">
      <Image
        src={hearsayLandingHero}
        alt="Abstract collage of torn paper, paint splatters, and bright shards in yellow, blue, red, and gold."
        class="hearsay-landing-hero__image"
        widths={[600, 720, 1080, 1440]}
        sizes="(min-width: 760px) 720px, 100vw"
        format="webp"
        loading="eager"
      />
    </figure>

    <HearsayFeed />

    {!isEmpty && <NewsletterPrompt />}
    {isEmpty && <ColumnSubscribePrompt column="hearsay" />}
  </div>
</BaseLayout>

<style>
  .hearsay-landing-hero {
    max-width: 720px;
    margin: 2rem auto 0;
    padding: 0 1.5rem;
  }

  .hearsay-landing-hero__image {
    width: 100%;
    height: auto;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    border: 1px solid var(--color-hearsay-600);
    border-radius: 2px;
    display: block;
  }
</style>
