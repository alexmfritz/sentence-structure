---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { readingTimeMinutes } from '../../lib/reading-time';
import { extractFirstLine } from '../../lib/content';
import { mdxComponents } from '../../lib/mdx-components';

export async function getStaticPaths() {
  const posts = await getCollection('off-the-record');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'off-the-record'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingMinutes = readingTimeMinutes(post.body ?? '');
const firstLine = post.data.title.trim()
  ? undefined
  : extractFirstLine(post.body ?? '');
---

<PostLayout
  column="off-the-record"
  title={post.data.title}
  deck={post.data.deck}
  firstLine={firstLine}
  publishedDate={post.data.publishedDate}
  readingMinutes={readingMinutes}
  tags={post.data.tags}
  body={post.body}
  heroImage={post.data.heroImage}
  crisisResources={post.data.crisisResources}
>
  <Content components={mdxComponents} />
</PostLayout>
