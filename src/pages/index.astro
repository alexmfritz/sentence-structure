---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/homepage/Hero.astro';
import MosaicAnchorRow from '../components/homepage/MosaicAnchorRow.astro';
import MosaicColumnShowcase from '../components/homepage/MosaicColumnShowcase.astro';
import MosaicArchiveSampler from '../components/homepage/MosaicArchiveSampler.astro';
import ManifestoStrip from '../components/homepage/ManifestoStrip.astro';
import HearsayStrip from '../components/homepage/HearsayStrip.astro';
import { getHomepageContent } from '../lib/homepage';
import { getHearsayPosts } from '../lib/hearsay';

const { hero, anchorRow, showcase, archiveSampler, isSparse } =
  await getHomepageContent();
const hearsayPosts = await getHearsayPosts();
---

<BaseLayout
  title="Sentence Structure — What They Don't Tell You"
  description="A blog about the prison experience. Memoir, journalism, satire, poetry, and the cognitive practice that came with all four."
>
  <header class="home-header">
    <h1 class="home-header__heading">
      <a href="/" class="home-header__wordmark">Sentence Structure</a>
    </h1>
  </header>

  <Hero post={hero} />

  {anchorRow.length > 0 && <MosaicAnchorRow posts={anchorRow} />}

  <MosaicColumnShowcase showcase={showcase} />

  {
    archiveSampler.length > 0 && (
      <MosaicArchiveSampler posts={archiveSampler} />
    )
  }

  {hearsayPosts.length > 0 && <HearsayStrip posts={hearsayPosts} />}

  <ManifestoStrip isSparse={isSparse} />
</BaseLayout>

<style>
  .home-header {
    position: absolute;
    top: 1.25rem;
    left: 1.5rem;
    z-index: 30;
  }

  .home-header__heading {
    margin: 0;
    font: inherit;
    font-weight: inherit;
  }

  .home-header__wordmark {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-text);
    text-decoration: none;
    background: var(--glass-floating);
    backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    padding: 0.5rem 0.95rem;
    transition: background 0.15s ease;
  }

  .home-header__wordmark:hover {
    background: var(--glass-floating-hover);
  }

  /* prefers-reduced-transparency handled globally in global.css. */
</style>
