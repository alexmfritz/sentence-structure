---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import TopNav from '../components/chrome/TopNav.astro';
import ReadingProgress from '../components/chrome/ReadingProgress.astro';
import NewsletterPrompt from '../components/chrome/NewsletterPrompt.astro';
import aboutHero from '../assets/about-hero.png';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    deck?: string;
    lastUpdated: string;
    contactEmail?: string;
  };
}

const { frontmatter } = Astro.props;
const lastUpdatedLabel = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(new Date(frontmatter.lastUpdated));

const contactEmail = frontmatter.contactEmail ?? 'hello@sentencestructure.blog';
---

<BaseLayout
  title={`${frontmatter.title} — Sentence Structure`}
  description={frontmatter.description ?? frontmatter.deck}
>
  <ReadingProgress variant="structural" />
  <TopNav />

  <article class="about">
    <header class="about__header">
      <p class="about__eyebrow">About</p>
      <h1 class="about__title">{frontmatter.title}</h1>
      {frontmatter.deck && <p class="about__deck">{frontmatter.deck}</p>}
    </header>

    <figure class="about__hero">
      <Image
        src={aboutHero}
        alt="Generative portrait of Alex Fritz: mouth open mid-shout, surrounded by runes, tentacles, and watching eyes."
        class="about__hero-image"
        widths={[560, 720, 1120]}
        sizes="(min-width: 720px) 560px, 100vw"
        format="webp"
        loading="eager"
      />
    </figure>

    <div class="about__byline">
      Last updated <time datetime={frontmatter.lastUpdated}>{lastUpdatedLabel}</time>
    </div>

    <div class="about__body">
      <slot />
    </div>

    <div class="about__contact">
      <p>
        <span class="about__contact-label">Contact</span>
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </p>
    </div>

    <NewsletterPrompt />
  </article>
</BaseLayout>

<style>
  .about__header {
    max-width: 560px;
    margin: 3rem auto 2rem;
    padding: 0 1.5rem;
  }

  .about__eyebrow {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-structural-200);
    margin: 0 0 0.75rem;
  }

  .about__title {
    font-family: var(--font-serif);
    font-size: clamp(30px, 2vw + 24px, 44px);
    line-height: 1.15;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .about__deck {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.4;
    font-style: italic;
    color: var(--color-text-secondary);
    margin: 1rem 0 0;
    max-width: 38ch;
  }

  .about__hero {
    max-width: 560px;
    margin: 0 auto 2rem;
    padding: 0 1.5rem;
  }

  .about__hero-image {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--color-structural-600);
    display: block;
  }

  /* Inline images within the essay body (from MDX). Same 1:1 frame
     as the hero, slightly narrower to read as supporting imagery. */
  .about__body :global(.about__inline-image) {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid var(--color-structural-600);
    display: block;
    margin: 2rem 0;
  }

  .about__byline {
    max-width: 560px;
    margin: 0 auto 2.5rem;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-secondary);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .about__body {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 1.5rem;
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.65;
    color: var(--color-text);
  }

  /* Body typography for the slotted MDX content. */
  .about__body :global(p) {
    margin: 0 0 1.6rem;
  }

  /* Asterism — chapbook-convention section break between the
     essay's natural movements. Structural purple to match the
     about page's accent (not column accents). */
  .about__body :global(.about__asterism) {
    text-align: center;
    font-size: 24px;
    line-height: 1;
    color: var(--color-structural-300);
    margin: 4rem 0;
    user-select: none;
  }

  .about__body :global(h2) {
    font-family: var(--font-sans);
    font-size: 24px;
    line-height: 1.25;
    font-weight: 500;
    color: var(--color-text);
    margin: 2.5rem 0 1rem;
  }

  .about__body :global(h3) {
    font-family: var(--font-sans);
    font-size: 19px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }

  .about__body :global(strong) {
    font-weight: 600;
  }

  .about__body :global(em) {
    font-style: italic;
  }

  /* About body uses structural purple for inline links — column
     accents would muddy the publication-wide framing. */
  .about__body :global(a) {
    color: var(--color-structural-200);
    text-decoration: underline;
    text-decoration-color: var(--color-structural-500);
    text-underline-offset: 0.2em;
  }

  .about__body :global(a:hover) {
    text-decoration-color: var(--color-structural-300);
  }

  .about__contact {
    max-width: 560px;
    margin: 3rem auto;
    padding: 1.5rem 1.5rem 0;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  .about__contact p {
    margin: 0;
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .about__contact-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
  }

  .about__contact a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-structural-500);
    text-underline-offset: 0.2em;
  }

  .about__contact a:hover {
    text-decoration-color: var(--color-structural-300);
  }
</style>
