---
import BaseLayout from './BaseLayout.astro';
import TopNav from '../components/chrome/TopNav.astro';
import ReadingProgress from '../components/chrome/ReadingProgress.astro';
import NewsletterPrompt from '../components/chrome/NewsletterPrompt.astro';
import ArticleHeader from '../components/post/ArticleHeader.astro';
import BylineStrip from '../components/post/BylineStrip.astro';
import { COLUMNS, type ColumnSlug } from '../lib/columns';
import type { Phase } from '../content.config';

interface Props {
  column: ColumnSlug;
  title: string;
  deck?: string;
  phase?: Phase;
  firstLine?: string;
  publishedDate: Date;
  readingMinutes: number;
  tags: string[];
}

const {
  column,
  title,
  deck,
  phase,
  firstLine,
  publishedDate,
  readingMinutes,
  tags,
} = Astro.props;

const meta = COLUMNS[column];
const titleForHead =
  title.trim() ||
  firstLine?.replace(/^[\s>*_`#-]+/, '').slice(0, 60) ||
  'Untitled';

const isOffTheRecord = column === 'off-the-record';
---

<BaseLayout
  title={`${titleForHead} — ${meta.name} — Sentence Structure`}
  description={deck}
>
  <div class="post-shell" data-column={column}>
    <ReadingProgress />
    <TopNav />

    <article class="post" data-column={column}>
      <div class="post__chrome">
        <ArticleHeader
          column={column}
          title={title}
          deck={deck}
          phase={phase}
          firstLine={firstLine}
        />
      </div>

      {
        !isOffTheRecord && (
          <div class="post__hero" aria-hidden="true">
            <div class="post__hero-block" />
          </div>
        )
      }

      <div class="post__chrome">
        <BylineStrip
          publishedDate={publishedDate}
          readingMinutes={readingMinutes}
        />
      </div>

      <div
        class:list={['post-body', isOffTheRecord && 'post-body--verse']}
        data-column={column}
      >
        <slot />
      </div>

      {
        tags.length > 0 && (
          <div class="post__chrome post__tags">
            <h2 class="post__tags-heading">Tags</h2>
            <ul>
              {tags.map((tag) => (
                <li>
                  <a href={`/archive?tags=${encodeURIComponent(tag)}`}>{tag}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <div class="post__chrome">
        <NewsletterPrompt />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .post {
    padding: 2rem 1.5rem 0;
  }

  .post__chrome,
  .post-body {
    max-width: 480px;
    margin: 0 auto;
  }

  .post__hero {
    max-width: 720px;
    margin: 1.5rem auto 2rem;
    padding: 0 1.5rem;
  }

  .post__hero-block {
    width: 100%;
    aspect-ratio: 2 / 1;
    background: color-mix(in oklch, var(--column-500) 38%, var(--color-bg-elevated));
    border: 1px solid var(--column-600);
    border-radius: 2px;
  }

  .post-body {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.65;
    color: var(--color-text);
    margin-bottom: 3rem;
  }

  .post-body--verse {
    line-height: 1.45;
  }

  /* ============================================================
     Markdown body typography. :global() lets the styles reach
     the elements rendered by the markdown processor.
     ============================================================ */

  .post-body :global(p) {
    margin: 0 0 1.25rem;
  }

  .post-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 24px;
    line-height: 1.25;
    font-weight: 500;
    color: var(--color-text);
    margin: 2.5rem 0 1rem;
  }

  .post-body :global(h3) {
    font-family: var(--font-sans);
    font-size: 19px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-text);
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(strong) {
    font-weight: 600;
  }

  .post-body :global(em) {
    font-style: italic;
  }

  .post-body :global(a) {
    color: var(--column-200);
    text-decoration: underline;
    text-decoration-color: var(--column-500);
    text-underline-offset: 0.2em;
  }

  .post-body :global(a:hover) {
    text-decoration-color: var(--column-300);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin: 0.25rem 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  /* clear floated sidenotes so they don't bleed past the body */
  .post-body::after {
    content: '';
    display: block;
    clear: both;
  }

  /* ============================================================
     Tags + chrome
     ============================================================ */

  .post__tags {
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-border);
  }

  .post__tags-heading {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0 0 0.75rem;
  }

  .post__tags ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post__tags a {
    display: inline-block;
    padding: 0.25rem 0.7rem;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-secondary);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    text-decoration: none;
  }

  .post__tags a:hover {
    color: var(--color-text);
    border-color: var(--color-text-tertiary);
  }
</style>
